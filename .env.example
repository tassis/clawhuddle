# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-random-secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain restriction (optional — only allow sign-in from this email domain)
ALLOWED_DOMAIN=

# Resend (invitation emails)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=ClawHuddle <noreply@yourdomain.com>
APP_URL=http://localhost:3000

# API Keys (for LLM proxy)
ANTHROPIC_API_KEY=

# Claw Proxy (optional) — route all gateways through Claude Max subscriptions
# 1. Start with: docker compose --profile proxy up -d
# 2. Put your tokens in data/claw-proxy/config.json (see vendor/claw-proxy/README.md)
# 3. Set the URL below and add the bearer token as an OpenAI key in the UI
OPENAI_BASE_URL=
# OPENAI_BASE_URL=http://claw-proxy:3456/v1

# Super Admin
SUPER_ADMIN_EMAIL=you@example.com

# Support email (shown in settings page)
NEXT_PUBLIC_SUPPORT_EMAIL=

# Member limit per organization (default 50)
MAX_MEMBERS_PER_ORG=50

# Database
DATABASE_PATH=./data/db.sqlite

# CORS (allowed origin for API requests)
CORS_ORIGIN=http://localhost:3000

# Docker / Traefik
DOCKER_NETWORK=clawhuddle-net
DOMAIN=localhost
# HOST_DATA_DIR must be an absolute path on the host machine (used for gateway Docker bind mounts).
# In docker-compose, this defaults to ${PWD}/data automatically. Override only if your data dir is elsewhere.
# HOST_DATA_DIR=/opt/clawhuddle/data
