# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-random-secret

# Internal OAuth providers (GitLab / Authentik)

# GitLab OAuth
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=

# Authentik OAuth (OIDC)
# AUTHENTIK_ISSUER must be the full issuer URL for your Authentik app, e.g.:
# https://auth.example.com/application/o/your-slug
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Optional local-development aid (not for production)
# Set to true to show credentials login flow in /login and /invite.
# NEXTAUTH_ENABLE_DEV_CREDENTIALS=false

# Domain restriction (optional — only allow sign-in from this email domain)
ALLOWED_DOMAIN=

# Resend (invitation emails)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=ClawHuddle <noreply@yourdomain.com>
APP_URL=http://localhost:3000

# API Keys (for LLM proxy)
ANTHROPIC_API_KEY=

# Claw Proxy (optional) — route gateways through Claude Max subscriptions
# 1. Start with: docker compose --profile proxy up -d
# 2. Put your tokens in data/claw-proxy/config.json (see vendor/claw-proxy/README.md)
# 3. Set the URL below, then add the bearer token as a "Claw Proxy" key in the UI
# CLAW_PROXY_URL=http://claw-proxy:3456/v1

# Internal LLMGW endpoint (optional override, defaults to https://llmgw.office.graidtech.com/v1)
LLMGW_BASE_URL=

# Super Admin
SUPER_ADMIN_EMAIL=you@example.com

# Support email (shown in settings page)
NEXT_PUBLIC_SUPPORT_EMAIL=

# Member limit per organization (default 50)
MAX_MEMBERS_PER_ORG=50

# Database
DATABASE_PATH=./data/db.sqlite

# CORS (allowed origin for API requests)
CORS_ORIGIN=http://localhost:3000

# Docker / Traefik
DOCKER_NETWORK=clawhuddle-net
DOMAIN=localhost
# HOST_DATA_DIR must be an absolute path on the host machine (used for gateway Docker bind mounts).
# In docker-compose, this defaults to ${PWD}/data automatically. Override only if your data dir is elsewhere.
# HOST_DATA_DIR=/opt/clawhuddle/data
